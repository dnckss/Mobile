{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "strict": true,
        "paths": {
            "@/*": ["./*"],
            "@components/*": ["./components/*"],
            "@screens/*": ["./screens/*"],
            "@type/*": ["./types/*"],
            "@mocks/^": ["./mock/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
    "exclude": ["node_modules"]
}
